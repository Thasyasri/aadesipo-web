{
  "name": "aadesipo-web",
  "private": true,
  "version": "0.1.0",
  "description": "AadesiPo — a desi-flavored, Monopoly-inspired mobile-first web game.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty",
    "test": "pnpm test:engine && pnpm test:app",
    "test:engine": "pnpm --filter @aadesipo/engine test",
    "test:app": "vitest run --config vitest.config.ts",
    "typecheck:functions": "cd supabase/functions && npx tsc -p tsconfig.json && npx tsc -p tsconfig.handlers.json",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "test:watch": "pnpm --filter @aadesipo/engine test:watch",
    "engine:build": "pnpm --filter @aadesipo/engine build",
    "prepare": "husky"
  },
  "dependencies": {
    "@aadesipo/engine": "workspace:*",
    "@sentry/react": "^10.63.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "canvas-confetti": "^1.9.4",
    "dexie": "^4.4.4",
    "howler": "^2.2.4",
    "motion": "^12.42.2",
    "pixi.js": "^8.19.0",
    "posthog-js": "^1.396.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.8.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/howler": "^2.2.13",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.6",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "!(supabase/functions/*/index.ts|supabase/functions/deno-stubs.d.ts)*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}

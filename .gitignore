# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
packages/*/dist/
*.tsbuildinfo

# Env
.env
.env.local
.env*.local

# Testing / coverage
coverage/

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Cloudflare
.wrangler/

# Supabase CLI local state
supabase/.temp/

# Stale in-place engine build artifacts (engine builds to dist/; src is TS-only).
# Two patterns: `**/*.js` misses files directly in src/, `*.js` covers those.
packages/engine/src/*.js
packages/engine/src/**/*.js

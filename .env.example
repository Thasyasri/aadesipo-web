# Copy to .env.local for local dev. Nothing here is required to run
# `pnpm dev` — every service below no-ops safely when its var is unset.

# Sentry (error tracking) — from sentry.io project settings
VITE_SENTRY_DSN=

# PostHog (analytics) — from posthog.com project settings
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase (auth + database + realtime) — added in M3
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
